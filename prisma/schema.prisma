// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")

}

enum Visibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

enum ProjectType {
  MOBILE
  WEB
}

model Project {
    id        String @id @default(auto()) @map("_id") @db.ObjectId
    userId   String
    name    String
    type ProjectType @default(MOBILE)
    theme String?
    thumbnail String?
    frames Frame[]
    
    visibility Visibility @default(PRIVATE)
    forkedFromId String? @db.ObjectId

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Frame {
    id        String    @id @default(auto()) @map("_id") @db.ObjectId
    title  String
    htmlContent String
    projectId String
    project Project @relation(fields: [projectId], references: [id])
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([projectId])
}

enum Role {
  USER
  ADMIN
}

model User {
  id        String   @id @map("_id") // We will map this to Kinde User ID manually or auto-generated
  email     String   @unique
  firstName String?
  lastName  String?
  credits   Int      @default(5) // 5 Free Credits for new users
  isUnlimited Boolean @default(false) // For Admin/Testing
  role      Role     @default(USER)
  
  stripeCustomerId String? // Future proofing
  
  studioDesigns StudioDesign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PaymentOrder {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  userId String // Link to User.id
  
  // Transaction Details
  provider String @default("PAYMOB") // PAYMOB, PAYPAL
  transactionId String? // External Provider ID
  paymobOrderId String? // Legacy/Specific
  
  amount Float
  currency String @default("EGP")
  creditsAmount Int @default(0)
  
  status String @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([currency])
}

model BlogPost {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String
  slug      String   @unique
  content   String
  excerpt   String
  image     String?
  author    String   @default("Osara AI")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  language  String   @default("en")
  tags      String[]
  category  String
}

model Feedback {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  projectId String   @db.ObjectId
  rating    Int      // e.g., 1 to 5 stars
  comment   String?  // Optional text feedback
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([userId])
}
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   // Link to User.id (Kinde ID)
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ALERT
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model StudioDesign {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  prompt    String
  imageUrl  String
  aspectRatio String
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TrendCategory {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nameAr    String
  nameEn    String
  prompts   TrendPrompt[]
  createdAt DateTime @default(now())
}

model TrendPrompt {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  titleAr     String
  titleEn     String
  prompt      String
  imagePreview String? // Useful for the gallery
  categoryId  String   @db.ObjectId
  category    TrendCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
}
